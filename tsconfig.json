{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": ".",
    "types": ["w3c-web-usb", "node", "vite/client"],
    "noEmit": true
  },
  "include": ["src/**/*.ts", "webapp/**/*.ts", "scripts/**/*.ts", "test/**/*.ts"]
}
